pipeline {
    agent none

    stages {

        stage('Ubuntu Check') {
            agent {
                label 'ubuntu-agent'
            }

            steps {
                sh '''
                java -version
                mvn -version
                '''
            }
       }
        stage('Fedora Check') {
            agent {
                label 'fedora-agent'
            }

            steps {
                sh '''
                java -version
                '''
            }
        }

        stage('Maven Build') {
    agent {
        label 'ubuntu-agent'
    }

    steps {
        sh '''
            cd maven-projekat
            mvn clean install
        '''

        stash includes: 'maven-projekat/target/*.jar', name: 'jar-file'
    }
}

stage('Ansible Deploy') {
    agent any

    steps {

        unstash 'jar-file'

        sh '''
            cd ansible
            ansible-playbook -i inventory playbook.yml
        '''
    }
}
    }
}
