pipeline {
    agent any

    stages {

        stage('UbuntuCheck') {
            agent {
                label 'ubuntu-agent'
            }

            steps {
                sh '''
                java -version
                mvn -version
                '''
            }
        }

        stage('FedoraCheck') {
            agent {
                label 'fedora-agent'
            }

            steps {
                sh 'java -version'
            }
        }

        stage('DockerCheck') {
            agent {
                docker {
                    image 'maven:latest'
                }
            }

            steps {
                sh 'echo "Radi Docker! ${BUILD_NUMBER}"'
            }
        }

        stage('Maven') {
            agent {
                label 'ubuntu-agent'
            }

            steps {
                sh 'mvn clean install'
            }
        }
    }
}
