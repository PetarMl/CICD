pipeline {
    agent any

    stages {

        stage('UbuntuCheck') {
            agent {
                label 'ubuntu-agent'
            }

            steps {
                sh '''
                java -version
                mvn -version
                '''
            }
        }

        stage('FedoraCheck') {
            agent {
                label 'fedora-agent'
            }

            steps {
                sh 'java -version'
            }
        }

        stage('Maven') {
            agent {
                label 'ubuntu-agent'
            }

            steps {
                sh '''
                   cd maven-projekat
                   mvn clean install
                   cd ../ansible
                   ansible-playbook -i inventory playbook.yml --private-key /var/lib/jenkins/.ssh/id_ed25519
                   '''
            }
        }
    }
}
